-
    // `meta.tagCloud` exists only when `group_by_lang` is enabled, and is
    // already scoped to the current page's language. Falling back to
    // `app.tagCloud` keeps the single-namespace case rendering exactly as
    // before — and keeps this partial working where there is no `meta`.
    const cloud = (typeof meta !== 'undefined' && meta && meta.tagCloud) || app.tagCloud || []

if cloud.length > 0
    section.tag-cloud
        each tag in cloud
            a.tag-cloud__item(href=`${ tag.href }`) #{ tag.name }
